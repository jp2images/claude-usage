<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClaudeUsage.Views.HistoryWindow"
        Title="Claude Usage — History"
        Width="660" Height="580"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="12">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="Claude Usage History"
                       FontWeight="Bold" FontSize="14" VerticalAlignment="Center" />
            <Button x:Name="RefreshButton" Grid.Column="1" Content="&#x21BA; Refresh" Padding="10,3" />
        </Grid>

        <Border DockPanel.Dock="Top" Height="1" Background="#33808080" Margin="0,8" />

        <ScrollViewer>
            <StackPanel x:Name="ContentPanel" />
        </ScrollViewer>
    </DockPanel>
</Window>
